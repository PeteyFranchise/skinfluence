{% liquid
  assign hero_eyebrow = section.settings.eyebrow
  assign hero_headline = section.settings.headline
  assign hero_subhead = section.settings.subhead
  assign primary_cta_url = section.settings.primary_cta_url
  assign secondary_cta_url = section.settings.secondary_cta_url
  assign evaluation_url = settings.evaluation_url | default: '/pages/start-evaluation'
  assign hero_art_asset = ''
  assign hero_image = section.settings.image
  assign hero_image_alt = section.settings.image_alt | escape

  if page != blank and hero_headline == blank
    assign hero_headline = page.title
  endif

  if request.page_type == 'index'
    assign hero_art_asset = 'skinfluence-hero-art.svg'
  endif

  if request.page_type == 'page' and template.suffix == 'legal'
    case page.handle
      when 'privacy-policy'
        assign hero_eyebrow = 'Privacy and data use'
        assign hero_headline = 'Privacy Policy'
        assign hero_subhead = '<p>How Skinfluence collects, uses, and protects the information shared through the storefront and evaluation process.</p>'
      when 'terms-of-service'
        assign hero_eyebrow = 'Website and service terms'
        assign hero_headline = 'Terms of Service'
        assign hero_subhead = '<p>The rules, limitations, and general conditions that govern use of the Skinfluence website and related services.</p>'
      when 'subscription-terms'
        assign hero_eyebrow = 'Billing and continuity'
        assign hero_headline = 'Subscription Terms'
        assign hero_subhead = '<p>How recurring billing, shipments, account management, and subscription-related expectations should work for Skinfluence users.</p>'
    endcase
  endif

  if request.page_type == 'page'
    case template.suffix
      when 'evaluation'
        assign hero_art_asset = 'skinfluence-evaluation-art.svg'
      when 'support'
        assign hero_art_asset = 'skinfluence-support-art.svg'
    endcase
  endif

  if section.settings.primary_cta_label contains 'Evaluation'
    if primary_cta_url == blank or primary_cta_url == '/pages/how-it-works'
      assign primary_cta_url = evaluation_url
    endif
  endif

  if section.settings.secondary_cta_label contains 'Evaluation'
    if secondary_cta_url == blank or secondary_cta_url == '/pages/how-it-works'
      assign secondary_cta_url = evaluation_url
    endif
  endif
%}

<section class="skinfluence-section skinfluence-hero">
  <div class="page-width">
    <div class="skinfluence-hero__layout">
      <div class="skinfluence-hero__copy">
        {% if hero_eyebrow != blank %}
          <p class="skinfluence-hero__eyebrow">{{ hero_eyebrow }}</p>
        {% endif %}

        {% if hero_headline != blank %}
          <h1 class="skinfluence-hero__headline">{{ hero_headline }}</h1>
        {% endif %}

        {% if hero_subhead != blank %}
          <div class="skinfluence-hero__subhead rte">{{ hero_subhead }}</div>
        {% endif %}

        <div class="skinfluence-hero__actions">
          {% if section.settings.primary_cta_label != blank and primary_cta_url != blank %}
            <a class="button button--primary" href="{{ primary_cta_url }}">
              {{ section.settings.primary_cta_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_cta_label != blank and secondary_cta_url != blank %}
            <a class="button button--secondary" href="{{ secondary_cta_url }}">
              {{ section.settings.secondary_cta_label }}
            </a>
          {% endif %}
        </div>
      </div>

      {% if hero_image != blank or hero_art_asset != blank %}
        <div class="skinfluence-hero__art">
          {% if hero_image != blank %}
            {{
              hero_image
              | image_url: width: 1400
              | image_tag:
                class: 'skinfluence-hero__art-image',
                loading: 'lazy',
                alt: hero_image_alt
            }}
          {% else %}
            <img
              class="skinfluence-hero__art-image"
              src="{{ hero_art_asset | asset_url }}"
              alt=""
              loading="lazy"
              width="960"
              height="960"
            >
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Skinfluence Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "headline", "label": "Headline" },
    { "type": "richtext", "id": "subhead", "label": "Subhead" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "image_alt", "label": "Hero image alt text" },
    { "type": "text", "id": "primary_cta_label", "label": "Primary CTA label" },
    { "type": "url", "id": "primary_cta_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary CTA URL" }
  ],
  "presets": [
    { "name": "Skinfluence Hero" }
  ]
}
{% endschema %}
