{% liquid
  assign hero_eyebrow = section.settings.eyebrow
  assign hero_headline = section.settings.headline
  assign hero_subhead = section.settings.subhead

  if page != blank and hero_headline == blank
    assign hero_headline = page.title
  endif

  if request.page_type == 'page' and template.suffix == 'legal'
    case page.handle
      when 'privacy-policy'
        assign hero_eyebrow = 'Privacy and data use'
        assign hero_headline = 'Privacy Policy'
        assign hero_subhead = '<p>How Skinfluence collects, uses, and protects the information shared through the storefront and evaluation process.</p>'
      when 'terms-of-service'
        assign hero_eyebrow = 'Website and service terms'
        assign hero_headline = 'Terms of Service'
        assign hero_subhead = '<p>The rules, limitations, and general conditions that govern use of the Skinfluence website and related services.</p>'
      when 'subscription-terms'
        assign hero_eyebrow = 'Billing and continuity'
        assign hero_headline = 'Subscription Terms'
        assign hero_subhead = '<p>How recurring billing, shipments, account management, and subscription-related expectations should work for Skinfluence users.</p>'
    endcase
  endif
%}

<section class="skinfluence-section skinfluence-hero">
  <div class="page-width">
    {% if hero_eyebrow != blank %}
      <p class="skinfluence-hero__eyebrow">{{ hero_eyebrow }}</p>
    {% endif %}

    {% if hero_headline != blank %}
      <h1 class="skinfluence-hero__headline">{{ hero_headline }}</h1>
    {% endif %}

    {% if hero_subhead != blank %}
      <div class="skinfluence-hero__subhead rte">{{ hero_subhead }}</div>
    {% endif %}

    <div class="skinfluence-hero__actions">
      {% if section.settings.primary_cta_label != blank and section.settings.primary_cta_url != blank %}
        <a class="button button--primary" href="{{ section.settings.primary_cta_url }}">
          {{ section.settings.primary_cta_label }}
        </a>
      {% endif %}

      {% if section.settings.secondary_cta_label != blank and section.settings.secondary_cta_url != blank %}
        <a class="button button--secondary" href="{{ section.settings.secondary_cta_url }}">
          {{ section.settings.secondary_cta_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Skinfluence Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "headline", "label": "Headline" },
    { "type": "richtext", "id": "subhead", "label": "Subhead" },
    { "type": "text", "id": "primary_cta_label", "label": "Primary CTA label" },
    { "type": "url", "id": "primary_cta_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary CTA URL" }
  ],
  "presets": [
    { "name": "Skinfluence Hero" }
  ]
}
{% endschema %}
