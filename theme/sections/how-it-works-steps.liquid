<section class="skinfluence-section skinfluence-steps">
  <div class="page-width">
    {% if section.settings.headline != blank %}
      <h2 class="skinfluence-section__headline">{{ section.settings.headline }}</h2>
    {% endif %}

    <div class="skinfluence-steps__grid">
      {% for block in section.blocks %}
        <div class="skinfluence-steps__card" {{ block.shopify_attributes }}>
          {% if block.settings.title != blank %}
            <h3 class="skinfluence-steps__title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.body != blank %}
            <div class="skinfluence-steps__body rte">{{ block.settings.body }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How It Works Steps",
  "settings": [
    { "type": "text", "id": "headline", "label": "Headline" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "How It Works Steps",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
