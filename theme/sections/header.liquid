<header class="skinfluence-site-header">
  <div class="page-width skinfluence-site-header__inner">
    <a class="skinfluence-site-header__brand" href="{{ routes.root_url }}">
      {{ shop.name }}
    </a>

    {% assign main_menu = linklists[section.settings.menu] %}
    {% if main_menu != blank %}
      <nav class="skinfluence-site-header__nav" aria-label="Primary">
        <ul class="skinfluence-site-header__menu list-unstyled" role="list">
          {% for link in main_menu.links %}
            <li class="skinfluence-site-header__menu-item">
              <a href="{{ link.url }}" class="skinfluence-site-header__link">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
      <div class="skinfluence-site-header__actions">
        <a class="button button--primary" href="{{ section.settings.cta_url }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {% endif %}
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Start Evaluation"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ]
}
{% endschema %}
