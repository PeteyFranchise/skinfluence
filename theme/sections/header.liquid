<header class="skinfluence-site-header">
  {% liquid
    assign header_cta_url = section.settings.cta_url
    assign evaluation_url = settings.evaluation_url | default: '/pages/start-evaluation'

    if section.settings.cta_label contains 'Evaluation'
      if header_cta_url == blank or header_cta_url == '/pages/how-it-works'
        assign header_cta_url = evaluation_url
      endif
    endif
  %}

  <div class="page-width skinfluence-site-header__inner">
    <a class="skinfluence-site-header__brand" href="{{ routes.root_url }}">
      {{ shop.name }}
    </a>

    {% assign main_menu = linklists[section.settings.menu] %}
    {% assign use_fallback_menu = false %}
    {% if main_menu == blank or section.settings.menu == blank or section.settings.menu == 'main-menu' %}
      {% assign use_fallback_menu = true %}
    {% endif %}

    {% if use_fallback_menu %}
      <nav class="skinfluence-site-header__nav" aria-label="Primary">
        <ul class="skinfluence-site-header__menu list-unstyled" role="list">
          <li class="skinfluence-site-header__menu-item">
            <a href="/pages/how-it-works" class="skinfluence-site-header__link">How It Works</a>
          </li>
          <li class="skinfluence-site-header__menu-item">
            <a href="/pages/treatment" class="skinfluence-site-header__link">Treatment</a>
          </li>
          <li class="skinfluence-site-header__menu-item">
            <a href="/pages/pricing" class="skinfluence-site-header__link">Pricing</a>
          </li>
          <li class="skinfluence-site-header__menu-item">
            <a href="/pages/faq" class="skinfluence-site-header__link">FAQ</a>
          </li>
        </ul>
      </nav>
    {% elsif main_menu != blank %}
      <nav class="skinfluence-site-header__nav" aria-label="Primary">
        <ul class="skinfluence-site-header__menu list-unstyled" role="list">
          {% for link in main_menu.links %}
            <li class="skinfluence-site-header__menu-item">
              <a href="{{ link.url }}" class="skinfluence-site-header__link">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    {% if section.settings.cta_label != blank and header_cta_url != blank %}
      <div class="skinfluence-site-header__actions">
        <a class="button button--primary" href="{{ header_cta_url }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {% endif %}
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Start Evaluation"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ]
}
{% endschema %}
