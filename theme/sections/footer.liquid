<footer class="skinfluence-site-footer">
  <div class="page-width skinfluence-site-footer__inner">
    <div class="skinfluence-site-footer__brand-block">
      <p class="skinfluence-site-footer__brand">{{ shop.name }}</p>
      {% if section.settings.brand_copy != blank %}
        <p class="skinfluence-site-footer__copy">
          {{ section.settings.brand_copy }}
        </p>
      {% endif %}
    </div>

    {% assign footer_menu = linklists[section.settings.footer_menu] %}
    {% assign use_fallback_footer_menu = false %}
    {% if footer_menu == blank or section.settings.footer_menu == blank or section.settings.footer_menu == 'footer' %}
      {% assign use_fallback_footer_menu = true %}
    {% endif %}

    {% if use_fallback_footer_menu %}
      <nav class="skinfluence-site-footer__nav" aria-label="Footer">
        <ul class="skinfluence-site-footer__menu list-unstyled" role="list">
          <li class="skinfluence-site-footer__menu-item">
            <a href="/pages/about" class="skinfluence-site-footer__link">About</a>
          </li>
          <li class="skinfluence-site-footer__menu-item">
            <a href="/pages/support" class="skinfluence-site-footer__link">Support</a>
          </li>
          <li class="skinfluence-site-footer__menu-item">
            <a href="/pages/faq" class="skinfluence-site-footer__link">FAQ</a>
          </li>
        </ul>
      </nav>
    {% elsif footer_menu != blank %}
      <nav class="skinfluence-site-footer__nav" aria-label="Footer">
        <ul class="skinfluence-site-footer__menu list-unstyled" role="list">
          {% for link in footer_menu.links %}
            <li class="skinfluence-site-footer__menu-item">
              <a href="{{ link.url }}" class="skinfluence-site-footer__link">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    {% assign legal_menu = linklists[section.settings.legal_menu] %}
    {% assign use_fallback_legal_menu = false %}
    {% if legal_menu == blank or section.settings.legal_menu == blank or section.settings.legal_menu == 'footer' %}
      {% assign use_fallback_legal_menu = true %}
    {% endif %}

    {% if use_fallback_legal_menu %}
      <nav class="skinfluence-site-footer__nav skinfluence-site-footer__nav--legal" aria-label="Legal">
        <ul class="skinfluence-site-footer__menu list-unstyled" role="list">
          <li class="skinfluence-site-footer__menu-item">
            <a href="/pages/privacy-policy" class="skinfluence-site-footer__link">Privacy Policy</a>
          </li>
          <li class="skinfluence-site-footer__menu-item">
            <a href="/pages/terms-of-service" class="skinfluence-site-footer__link">Terms of Service</a>
          </li>
          <li class="skinfluence-site-footer__menu-item">
            <a href="/pages/subscription-terms" class="skinfluence-site-footer__link">Subscription Terms</a>
          </li>
        </ul>
      </nav>
    {% elsif legal_menu != blank %}
      <nav class="skinfluence-site-footer__nav skinfluence-site-footer__nav--legal" aria-label="Legal">
        <ul class="skinfluence-site-footer__menu list-unstyled" role="list">
          {% for link in legal_menu.links %}
            <li class="skinfluence-site-footer__menu-item">
              <a href="{{ link.url }}" class="skinfluence-site-footer__link">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_copy",
      "label": "Brand copy",
      "default": "Premium clinical skincare designed around provider-reviewed anti-aging care."
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal menu"
    }
  ]
}
{% endschema %}
