<section class="skinfluence-section skinfluence-cta-banner">
  <div class="page-width">
    <div class="skinfluence-cta-banner__inner">
      {% if section.settings.headline != blank %}
        <h2 class="skinfluence-section__headline">{{ section.settings.headline }}</h2>
      {% endif %}

      {% if section.settings.subhead != blank %}
        <div class="skinfluence-cta-banner__subhead rte">{{ section.settings.subhead }}</div>
      {% endif %}

      {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
        <a class="button button--primary" href="{{ section.settings.cta_url }}">
          {{ section.settings.cta_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Skinfluence CTA Banner",
  "settings": [
    { "type": "text", "id": "headline", "label": "Headline" },
    { "type": "richtext", "id": "subhead", "label": "Subhead" },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [
    { "name": "Skinfluence CTA Banner" }
  ]
}
{% endschema %}
