{{ 'section-video-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign video_ratio = section.settings.video_ratio
  assign has_asset_video = false
  assign has_asset_image = false
  assign asset_image_name = section.settings.image_asset
  if section.settings.video_asset != blank
    assign has_asset_video = true
  endif
  if asset_image_name == blank and section.id == '4a48dd22-7a83-42ba-ae14-de6aaae18074'
    assign asset_image_name = 'protocl-hero-static.png'
  endif
  if asset_image_name != blank
    assign has_asset_image = true
  endif
  assign asset_video_id = 'AssetVideo-' | append: section.id
-%}

{%- if video_ratio == 'adapt' and section.settings.video != blank -%}
  {%- style -%}
    @media screen and (min-width: 750px) {
      #Banner-{{ section.id }}.video--overlay::before {
        padding-bottom: {{ 1 | divided_by: section.settings.video.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
    #Banner-{{ section.id }} .video-banner__media::before {
      padding-bottom: {{ 1 | divided_by: section.settings.video.aspect_ratio | times: 100 }}%;
      content: '';
      display: block;
    }
  {%- endstyle -%}
{%- elsif video_ratio == 'adapt' and section.settings.video == blank and has_asset_video == false and has_asset_image == false -%}
  {%- style -%}
    @media screen and (min-width: 750px) {
      #Banner-{{ section.id }}.video--overlay::before {
        padding-bottom: 25%;
        content: '';
        display: block;
      }
    }
    #Banner-{{ section.id }}.video-banner--no-video::before, #Banner-{{ section.id }} .video-banner__media::before {
      padding-bottom: 25%;
      content: '';
      display: block;
    }
  {%- endstyle -%}
{%- endif -%}
{%- if video_ratio != "adapt" %}
  {% assign aspect_ratio = section.settings.video_ratio | split: '/' %}
  {% assign temp = aspect_ratio[0] | append: '.0' %}
  {% assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2 %}
  {%- style -%}
    @media screen and (min-width: 750px) {
      #Banner-{{ section.id }}.video--overlay::before {
        content: '';
        display: block;
        padding-bottom: {{ padding_bottom }}%;
      }
    }

    #Banner-{{ section.id }}.video-banner--no-video::before, #Banner-{{ section.id }} .video-banner__media::before {
      content: '';
      display: block;
      padding-bottom: {{ padding_bottom }}%;
    }
  {%- endstyle -%}
{%- endif -%}

{% style %}
  .section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.padding_top | times: 0.25 | round: 0 }}px;
	  padding-bottom: {{ section.settings.padding_bottom | times: 0.25 | round: 0 }}px;
	}

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    	padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
  }

	@media screen and (min-width: 1360px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}

  .video-banner__overlay {
    background-color: rgba(var(--color-overlay), {{ section.settings.opacity_overlay }});
  }

  {%- if has_asset_image -%}
    #Banner-{{ section.id }} {
      background-image: url('{{ asset_image_name | asset_url }}');
      background-position: center center;
      background-repeat: no-repeat;
      background-size: cover;
      min-height: 32rem;
    }

    @media screen and (min-width: 750px) {
      #Banner-{{ section.id }} {
        min-height: 48rem;
      }
    }
  {%- endif -%}
{% endstyle %}

<div class="
    video-banner 
    {% if section.settings.full_width %}{% else %}container{% endif %} 
    {% if section.settings.header_overlay %} section--has-overlay header--overlay {% endif %}
    section-{{ section.id }}-padding
  "
>
  <div
    id="Banner-{{ section.id }}"
    class="
      video-banner__content video--overlay 
      {% if section.settings.full_width %}video-banner--container{% endif %} 
      {%- if section.settings.video == blank and has_asset_video == false and has_asset_image == false -%} video-banner--no-video {% endif %}
      color-{{ section.settings.color_scheme }}
    "
  >
    {%- if section.settings.video != blank -%}
      <div class="video-banner__media media video-banner__media--{{- section.settings.video_fit -}}">
        {{ section.settings.video
          | video_tag:
            image_size: "1100x",
            autoplay: true,
            loop: true,
            controls: false,
            muted: true
        }}
        <span class="video-banner__overlay"></span>
      </div>
    {%- elsif has_asset_video -%}
      <div class="video-banner__media media video-banner__media--{{- section.settings.video_fit -}}">
        <video id="{{ asset_video_id }}" autoplay muted loop playsinline preload="none" data-lazy-video>
          <source data-src="{{ section.settings.video_asset | asset_url }}" type="video/mp4">
        </video>
        <span class="video-banner__overlay"></span>
      </div>
    {%- elsif has_asset_image -%}
      <span class="video-banner__overlay"></span>
    {%- endif -%}
    <div class="video-banner__wrapper {% if section.settings.text_align != 'left' %}video-banner__column--center{% endif %} {% if section.settings.full_width %}container{% else %}{% endif %}">
      {%- if section.settings.subheading != blank -%}
        <div class="video-banner__subheading subtitle">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}
      <div class="video-banner__column video-banner__column--column">
        {%- if section.settings.heading != blank -%}
          <h2 class="video-banner__heading title--section title--decorate title--section-mt-none {% if section.settings.heading_size == 'medium' %}h2{% else %}h1{% endif %}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text_information != blank or section.settings.show_view_all -%}
          <div class="video-banner__information">
            {%- if section.settings.text_information != blank -%}
              <p class="video-banner__text">
                {{ section.settings.text_information | escape }}
              </p>
            {%- endif -%}

            {%- if section.settings.show_view_all -%}
							<a
								{% if section.settings.button_link != blank %}
									href="{{ section.settings.button_link }}"
								{% endif %}
								class="button video-banner__button button--arrow button--primary-size button--{{ section.settings.button_style }}"
								{% if section.settings.button_link == blank %}
									aria-disabled="true"
								{% endif %}
							>
								<span>
									<span>
										{{- section.settings.button_label | escape -}}
										{%- render 'icon-button-arrow' -%}
									</span>
									<span>
										{{- section.settings.button_label | escape -}}
										{%- render 'icon-button-arrow' -%}
									</span>
								</span>
							</a>
						{%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- if has_asset_video -%}
  <script>
    (() => {
      const video = document.getElementById('{{ asset_video_id }}');
      if (!video || video.dataset.loaded === 'true') return;

      const loadVideo = () => {
        if (video.dataset.loaded === 'true') return;
        const source = video.querySelector('source[data-src]');
        if (!source) return;
        source.src = source.dataset.src;
        video.load();
        const playAttempt = video.play();
        if (playAttempt && typeof playAttempt.catch === 'function') {
          playAttempt.catch(() => {});
        }
        video.dataset.loaded = 'true';
      };

      if (!('IntersectionObserver' in window)) {
        loadVideo();
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          loadVideo();
          observer.disconnect();
        });
      }, {
        rootMargin: '200px 0px'
      });

      observer.observe(video);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.video-banner.name",
  "tag": "section",
  "class": "video-banner-section spaced-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "t:sections.video-banner.settings.full_width.label"
    },
    {
      "type": "checkbox",
      "id": "header_overlay",
      "default": false,
      "label": "t:sections.video-banner.settings.header_overlay.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "background-1",
          "label": "t:sections.video-banner.settings.color_scheme.options__1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.video-banner.settings.color_scheme.options__2.label"
        },
        {
          "value": "background-3",
          "label": "t:sections.video-banner.settings.color_scheme.options__3.label"
        },
        {
          "value": "background-4",
          "label": "t:sections.video-banner.settings.color_scheme.options__4.label"
        }
      ],
      "default": "background-1",
      "label": "t:sections.video-banner.settings.color_scheme.label"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "t:sections.video-banner.settings.subheading.default",
      "label": "t:sections.video-banner.settings.subheading.label"
    },
    {
      "type": "richtext",
      "id": "heading",
      "default": "t:sections.video-banner.settings.heading.default",
      "label": "t:sections.video-banner.settings.heading.label"
    },
    {
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "medium",
					"label": "t:sections.video-banner.settings.heading_size.options__1.label"
				},
				{
					"value": "large",
					"label": "t:sections.video-banner.settings.heading_size.options__2.label"
				}
			],
			"default": "medium",
			"label": "t:sections.video-banner.settings.heading_size.label"
		},
    {
      "type": "textarea",
      "id": "text_information",
      "default": "t:sections.video-banner.settings.text_information.default",
      "label": "t:sections.video-banner.settings.text_information.label"
    },
    {
      "type": "select",
      "id": "text_align",
      "options": [
        {
          "value": "left",
          "label": "t:sections.video-banner.settings.text_align.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.video-banner.settings.text_align.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.video-banner.settings.text_align.label"
    },
    {
      "type": "header",
      "content": "t:sections.video-banner.settings.header__1.content"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "t:sections.video-banner.settings.show_view_all.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.video-banner.settings.button_label.default",
      "label": "t:sections.video-banner.settings.button_label.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.video-banner.settings.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.video-banner.settings.button_style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.video-banner.settings.button_style.label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.video-banner.settings.button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.video-banner.settings.header__2.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video-banner.settings.video.label"
    },
    {
      "type": "text",
      "id": "video_asset",
      "label": "Video asset filename",
      "info": "Optional theme asset filename for an MP4 video."
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Image asset filename",
      "info": "Optional theme asset filename for a static hero image."
    },
    {
      "type": "select",
      "id": "video_ratio",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.video-banner.settings.video_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.video-banner.settings.video_ratio.options__2.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.video-banner.settings.video_ratio.options__3.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.video-banner.settings.video_ratio.options__4.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.video-banner.settings.video_ratio.options__5.label"
        },
        {
          "value": "adapt",
          "label": "t:sections.video-banner.settings.video_ratio.options__6.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.video-banner.settings.video_ratio.label"
    },
    {
      "type": "select",
      "id": "video_fit",
      "label": "t:sections.video-banner.settings.video_fit.label",
      "options": [
        {
        "value": "contain",
        "label": "t:sections.video-banner.settings.video_fit.options__1.label"
        },
        {
        "value": "cover",
        "label": "t:sections.video-banner.settings.video_fit.options__2.label"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "opacity_overlay",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "t:sections.video-banner.settings.opacity_overlay.label",
      "default": 0.5
    },
    		{
			"type": "header",
			"content": "t:all.section-padding.header.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:all.section-padding.padding_top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:all.section-padding.padding_bottom.label"
		}
  ],
  "presets": [
    {
      "name": "t:sections.video-banner.presets.name"
    }
  ]
}
{% endschema %}
