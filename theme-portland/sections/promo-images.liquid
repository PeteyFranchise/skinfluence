{{ 'section-promo-images.css' | asset_url | stylesheet_tag }}

<script src="{{ 'parallax.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'promo-images.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.25 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.25 | round: 0 }}px;
  }

	@media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    	padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1360px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="promo-images section-{{ section.id }}-padding">
	<div class="promo-images-container">
		<div class="container">
			<div class="promo-images__wrapper color-background-2 promo-images__wrapper--{{ section.settings.heading_size }}">
	
				{%- if section.settings.heading != blank -%}
					<{{ section.settings.heading_tag }} class="promo-images__title title--section {{ section.settings.heading_size }} promo-images__title--{{ section.settings.heading_transform }}">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
				{% endif %}
	
				{%- if section.settings.button_label != blank -%}
					<a {% if section.settings.button_link != blank %} href="{{ section.settings.button_link }}"{% endif %} class="promo-images__link button button--primary-size button--{{ section.settings.button_style }}" {% if section.settings.button_link == blank %} aria-disabled="true"{% endif %}>
						<span>
							<span>
								{{ section.settings.button_label | escape }}
								{% render 'icon-button-arrow' %}
							</span>
							<span>
								{{ section.settings.button_label | escape }}
								{% render 'icon-button-arrow' %}
							</span>
						</span>
					</a>
				{%- endif -%}
	
			</div>
		</div>
		<div class="promo-images__container container">
			<div class="promo-images__images">
				{%- for block in section.blocks -%}
					<div class="promo-images__image js-parallax{% if block.settings.image == blank %} promo-images__image--with-placeholder{% endif %}" data-parallax-property="translateY" data-parallax-property-value="" data-parallax-steps="0, 100">
						{%- if block.settings.image != blank -%}
							{%- assign image_size = block.settings.image.width | append: 'x' -%}
							{%- assign image_size_2x = block.settings.image.width | times: 2 | append: 'x' -%}
							<img srcset="{{ block.settings.image | image_url: width: image_size }} 1x, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
										src="{{ block.settings.image | image_url: width: image_size }}"
										alt="{{ block.settings.image.alt | escape }}"
										width="{{ image_size }}"
										height="{{ block.settings.image.height }}"
										loading="lazy"
										{{ block.shopify_attributes }}
							>
						{%- else -%}
							{% assign placeholder_index = forloop.index | modulo: 6 | plus: 1 %}
							{{ 'collection-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg placeholder' }}
						{%- endif -%}
					</div>
				{%- endfor -%}
			</div>
		</div>
	</div>
</div>



{% schema %}
{
	"name": "t:sections.promo-images.name",
	"tag": "section",
	"class": "promo-images-section spaced-section",
	"enabled_on": {
    "templates": ["*"]
  },
	"max_blocks": 3,
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"default": "t:sections.promo-images.settings.heading.default",
			"label": "t:sections.promo-images.settings.heading.label"
		},
		{
			"type": "select",
			"id": "heading_tag",
			"options": [
				{
					"value": "h1",
					"label": "t:all.heading_tag.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:all.heading_tag.options__2.label"
				},
				{
					"value": "h3",
					"label": "t:all.heading_tag.options__3.label"
				},
				{
					"value": "h4",
					"label": "t:all.heading_tag.options__4.label"
				},
				{
					"value": "h5",
					"label": "t:all.heading_tag.options__5.label"
				},
				{
					"value": "h6",
					"label": "t:all.heading_tag.options__6.label"
				},
				{
					"value": "div",
					"label": "t:all.heading_tag.options__7.label"
				},
				{
					"value": "p",
					"label": "t:all.heading_tag.options__8.label"
				}
			],
			"default": "h2",
			"label": "t:all.heading_tag.label",
			"info": "t:all.heading_tag.info"
		},
		{
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.promo-images.settings.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.promo-images.settings.heading_size.options__2.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.promo-images.settings.heading_size.label"
    },
		{
      "type": "select",
      "id": "heading_transform",
      "options": [
        {
          "value": "uppercase",
          "label": "t:sections.promo-images.settings.heading_transform.options__1.label"
        },
        {
          "value": "none",
          "label": "t:sections.promo-images.settings.heading_transform.options__2.label"
        }
      ],
      "default": "none",
      "label": "t:sections.promo-images.settings.heading_transform.label"
    },
		{
			"type": "text",
			"id": "button_label",
			"default": "t:sections.promo-images.settings.button_label.default",
			"label": "t:sections.promo-images.settings.button_label.label"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "t:sections.promo-images.settings.button_link.label"
		},
		{
			"type": "select",
			"id": "button_style",
			"options": [
				{
					"value": "primary",
					"label": "t:sections.promo-images.settings.button_style.options__1.label"
				},
				{
					"value": "secondary",
					"label": "t:sections.promo-images.settings.button_style.options__2.label"
				},
				{
          "value": "tertiary",
          "label": "t:all.button.button_style.options__3.label"
        }
			],
			"default": "primary",
			"label": "t:sections.promo-images.settings.button_style.label"
		},
		{
			"type": "header",
			"content": "t:all.section-padding.header.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:all.section-padding.padding_top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:all.section-padding.padding_bottom.label"
		}
	],
	"blocks": [
		{
			"type": "promo-images_image",
			"name": "t:sections.promo-images.blocks.promo-images_image.name",
			"settings": [
				{
					"type": "image_picker",
					"id": "image",
					"label": "t:sections.promo-images.blocks.promo-images_image.settings.image.label",
					"info": "t:sections.promo-images.blocks.promo-images_image.settings.image.info"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.promo-images.presets.name",
			"blocks": [
				{
					"type": "promo-images_image"
				},
				{
					"type": "promo-images_image"
				},
				{
					"type": "promo-images_image"
				}
			]
		}
	]
}
{% endschema %}
