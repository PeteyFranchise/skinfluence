{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card-row.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}

<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-article-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-article-card-row.css' | asset_url | stylesheet_tag }}</noscript>

{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.25 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.25 | round: 0 }}px;
  }

	@media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    	padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1360px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
	<div class="blog {% if section.settings.post_layout == 'row' %} blog--row {% endif %} container">
		{%- if section.settings.heading != blank or section.settings.show_view_all -%}
			<div class="blog__title-wrapper">
				{%- if section.settings.heading != blank -%}
					<h2 class="blog__title title--section {% if section.settings.post_layout == 'row' %} subtitle {% endif %}">
						{{ section.settings.heading }}
					</h2>
				{%- endif -%}
	
				{%- if section.settings.show_view_all -%}
					{%- if section.settings.post_limit < section.settings.blog.articles_count or section.settings.blog == blank -%}
						<div class="blog__button-wrapper">
							{%- if section.settings.blog != blank -%}
								<a
									href="{{ section.settings.blog.url }}"
									class="blog__button {% if section.settings.post_layout == 'column' %} button--simple-move {% endif %} {% if section.settings.post_layout == 'row' %} button--simple {% endif %}"
								>
									<span>{{ 'sections.featured_blog.view_all' | t }}</span> {% render 'icon-button-arrow' %}
								</a>
							{%- else -%}
								<span
									class="blog__button {% if section.settings.post_layout == 'column' %} button--simple-move {% endif %} {% if section.settings.post_layout == 'row' %} button--simple {% endif %}"
								>
									<span>{{ 'sections.featured_blog.view_all' | t }}</span> {% render 'icon-button-arrow' %}
								</span>
							{%- endif -%}
						</div>
					{%- endif -%}
				{%- endif -%}
			</div>
		{%- endif -%}
		{%- liquid
			if section.settings.post_limit <= section.settings.blog.articles_count
				assign posts_exceed_limit = true
			endif -%}
		{%- if section.settings.blog != blank and section.settings.blog.articles_count > 0 -%}
			<ul class="blog__posts blog__posts--{{ section.settings.post_layout }} articles-wrapper {% if posts_exceed_limit %} blog__posts--{{ section.settings.post_limit }}-items{% else %} blog__posts--{{ section.settings.blog.articles_count }}-items{% endif %}"
					role="list"
			>
				{%- for article in section.settings.blog.articles limit: section.settings.post_limit -%}
					<li class="blog__post article">
						{% if section.settings.post_layout == 'column' %}
							{% render 'article-card', blog: section.settings.blog, article: article, show_image: section.settings.show_image, show_tags: section.settings.show_tags, show_date: section.settings.show_date, show_author: section.settings.show_author, show_excerpt: section.settings.show_excerpt %}
						{% elsif section.settings.post_layout == 'row' %}	
							{% render 'article-card-row', blog: section.settings.blog, article: article, show_image: section.settings.show_image, show_tags: section.settings.show_tags, show_date: section.settings.show_date, show_author: section.settings.show_author, show_excerpt: section.settings.show_excerpt %}
						{% endif %}
					</li>
				{%- endfor -%}
			</ul>
		{%- else -%}
			<ul class="blog__posts blog__posts--{{- section.settings.post_layout }} articles-wrapper blog__posts blog__posts--3-items">
				{% for i in (1..3) %}
					{%- if section.settings.post_layout == "column" -%}
						<li class="blog__post article">
							<article class="article-card">
								<div class="article-card__image-wrapper">
									{%- if section.settings.show_image -%}
										<div class="article-card__image media media--landscape">
											{% assign placeholder_index = forloop.index | modulo: 6 | plus: 1 %}
											{{ 'collection-'|  append: placeholder_index | placeholder_svg_tag: 'placeholder-svg' }}
										</div>
									{%- endif -%}
								</div>
								<div class="article-content motion-reduce">
									{%- if section.settings.show_tags -%}
										<ul class="article-card__tags">
											<li class="article-card__tag">
												<span>{{ 'sections.featured_blog.tag_placeholder' | t }}</span>
											</li>
										</ul>
									{%- endif -%}
									<div class="article-card__info">
										<header class="article-card__header">
											<h2 class="article-card__title h4">
												{{ 'sections.featured_blog.onboarding_title' | t }}
											</h2>
											<div class="article-card__meta">
												{%- if section.settings.show_date -%}
													<span class="line-divider">
													{{- 'today' | date: '%B %d, %Y' -}}
												</span>
												{%- endif -%}
												{%- if section.settings.show_author -%}
													<span class="article-card__author line-divider">
														{{- 'general.blog.author' | t -}}
														<span>{{ 'sections.featured_blog.author_placeholder' | t }}</span>
													</span>
												{%- endif -%}
											</div>
										</header>
										{%- if section.settings.show_excerpt -%}
											<p class="article-card__excerpt">
												{{ 'sections.featured_blog.onboarding_content' | t }}
											</p>
										{%- endif -%}
									</div>
								</div>
							</article>
						</li>
					{%- else -%}
						<li class="blog__post article">
							<article class="article-card-row">
								<div class="article-content-row motion-reduce">
									<div class="article-card-row__info">
										{%- if section.settings.show_tags -%}
											<ul class="article-card-row__tags">
												<li class="article-card-row__tag">
													<span>{{ 'sections.featured_blog.tag_placeholder' | t }}</span>
												</li>
											</ul>
										{%- endif -%}
										<header class="article-card-row__header">
											<h2 class="article-card-row__title h4">
												{{ 'sections.featured_blog.onboarding_title' | t }}
											</h2>
											<div class="article-card-row__meta">
												{%- if section.settings.show_date -%}
													<span class="line-divider">
														{{- 'today' | date: '%B %d, %Y' -}}
													</span>
												{%- endif -%}
												{%- if section.settings.show_author -%}
													<span class="article-card-row__author line-divider">
														{{- 'general.blog.author' | t -}}
														<span>{{ 'sections.featured_blog.author_placeholder' | t }}</span>
													</span>
												{%- endif -%}
											</div>
										</header>
										{%- if section.settings.show_excerpt -%}
											<p class="article-card-row__excerpt">
												{{ 'sections.featured_blog.onboarding_content' | t }}
											</p>
										{%- endif -%}
									</div>
								</div>
								<div class="article-card-row__image-wrapper">
									{%- if section.settings.show_image -%}
										<div class="article-card-row__image media media--landscape">
											{% assign placeholder_index = forloop.index | modulo: 6 | plus: 1 %}
											{{ 'collection-'|  append: placeholder_index | placeholder_svg_tag: 'placeholder-svg' }}
										</div>
									{%- endif -%}
								</div>
							</article>
						</li>
					{%- endif -%}
				{% endfor %}
			</ul>
		{%- endif -%}
	</div>
</div>

{% schema %}
{
	"name": "t:sections.featured-blog.name",
	"tag": "section",
	"class": "spaced-section section-featured-blog",
	"enabled_on": {
    "templates": ["*"]
  },
	"settings": [
		{
			"type": "select",
			"id": "post_layout",
			"options": [
				{
					"value": "column",
					"label": "t:sections.featured-blog.settings.post_layout.options__1.label"
				},
				{
					"value": "row",
					"label": "t:sections.featured-blog.settings.post_layout.options__2.label"
				}
			],
			"default": "column",
			"label": "t:sections.featured-blog.settings.post_layout.label"
		},
		{
			"type": "richtext",
			"id": "heading",
			"default": "t:sections.featured-blog.settings.heading.default",
			"label": "t:sections.featured-blog.settings.heading.label"
		},
		{
			"type": "blog",
			"id": "blog",
			"label": "t:sections.featured-blog.settings.blog.label"
		},
		{
			"type": "range",
			"id": "post_limit",
			"min": 1,
			"max": 3,
			"step": 1,
			"default": 3,
			"label": "t:sections.featured-blog.settings.post_limit.label"
		},
		{
			"type": "checkbox",
			"id": "show_image",
			"default": true,
			"label": "t:sections.featured-blog.settings.show_image.label",
			"info": "t:sections.featured-blog.settings.show_image.info"
		},
		{
			"type": "checkbox",
			"id": "show_tags",
			"default": true,
			"label": "t:sections.main-blog.settings.show_tags.label"
		},
		{
			"type": "checkbox",
			"id": "show_date",
			"default": true,
			"label": "t:sections.featured-blog.settings.show_date.label"
		},
		{
			"type": "checkbox",
			"id": "show_author",
			"default": false,
			"label": "t:sections.featured-blog.settings.show_author.label"
		},
		{
			"type": "checkbox",
			"id": "show_excerpt",
			"default": false,
			"label": "t:sections.featured-blog.settings.show_excerpt.label"
		},
		{
			"type": "checkbox",
			"id": "show_view_all",
			"default": true,
			"label": "t:sections.featured-blog.settings.show_view_all.label"
		},
		{
			"type": "header",
			"content": "t:all.section-padding.header.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 160,
			"unit": "px",
			"label": "t:all.section-padding.padding_top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 160,
			"unit": "px",
			"label": "t:all.section-padding.padding_bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.featured-blog.presets.name",
			"settings": {
				"blog": "News"
			}
		}
	]
}
{% endschema %}
