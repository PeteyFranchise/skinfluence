						<details class="header__details">
							<summary class="link-hover-line-outer header__icon header__icon--search header__icon--summary focus-inset modal__toggle" aria-haspopup="dialog" aria-label="{{ 'general.search.search' | t }}">
								<svg class="modal__toggle-open icon icon-search" aria-hidden="true" focusable="false" role="presentation">
									<use href="#icon-search">
								</svg>
								<span class="header__icon-name" title="{{- 'general.search.search' | t -}}">
								{{- 'general.search.search' | t -}}
