		{%- if request.page_type == 'index' -%}
			<h1 class="header__heading">
				{%- endif -%}
				<a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
					{%- if section.settings.logo != blank -%}
						{%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio -%}
						{%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
						{%- assign image_size_2x = section.settings.logo_width | times: 2 -%}
						{% capture srcset %}
							{{ section.settings.logo | image_url: width: section.settings.logo_width }}, {{ section.settings.logo | image_url: width: image_size_2x }} 2x
						{% endcapture %}
						{{ section.settings.logo | image_url: width: section.settings.logo_width | image_tag:
							class: 'header__heading-logo',
							srcset: srcset,
							height: logo_height,
							width: section.settings.logo_width,
							alt: logo_alt
						}}
						{%- if section.settings.logo_2 != blank -%}
							{% capture srcset %}
								{{ section.settings.logo_2 | image_url: width: section.settings.logo_width }}, {{ section.settings.logo_2 | image_url: width: image_size_2x }} 2x
							{% endcapture %}
							{{ section.settings.logo_2 | image_url: width: section.settings.logo_width | image_tag:
								class: 'header__heading-logo header__heading-logo--overlay',
								srcset: srcset,
								height: logo_height,
								width: section.settings.logo_width,
								alt: logo_alt
							}}
						{%- endif -%}
					{%- else -%}
						<span class="h5" style="max-width:{{ section.settings.logo_width }}px">{{ shop.name }}</span>
					{%- endif -%}
				</a>
				{%- if request.page_type == 'index' -%}
			</h1>
		{%- endif -%}

		<nav class="header__inline-menu header__inline-menu--js">
			{%- if section.settings.menu != blank -%}
				<ul class="list-menu list-menu--inline" role="list">
					{%- for link in section.settings.menu.links -%}
						{% assign mega_menu = false %}
						{% assign mega_menu_2 = false %}
						{% assign mega_submenu = false %}
							{%- if link.links != blank -%}
								{% if section.blocks.size > 0 %}
									{% for block in section.blocks %}
										{% liquid
											assign mega_menu_trigger = block.settings.mega_menu_trigger | handle | strip
											assign mega_menu_2_trigger = block.settings.mega_menu_2_trigger | handle | strip

											if link.handle == mega_menu_trigger
												assign mega_menu = true
												assign mega_menu_2 = false
												assign shopify_attributes = block.shopify_attributes
											elsif link.handle == mega_menu_2_trigger
												assign mega_menu_2 = true
												assign mega_menu = false
												assign shopify_attributes = block.shopify_attributes
											endif
										%}

										{% assign mega_submenu_trigger = block.settings.mega_submenu_trigger | handle | strip %}

										{% if link.handle == mega_submenu_trigger and block.type == 'mega_submenu' and link.links != blank %}
											{% assign mega_submenu = true %}
										{% endif %}
									{% endfor %}
								{% endif %}
								
								<li class="{% if mega_menu or mega_menu_2 or mega_submenu %}list-menu--megamenu{% endif %} {% if mega_submenu %} list-menu--megasubmenu{% endif %}" {{ shopify_attributes }}>
									<span class="header__menu-item link-hover-line-outer list-menu__item link focus-inset">
										<span class="link-hover-line-outer {%- if link.active %} header__active-menu-item{% endif %} "title="{{ link.title | escape }}">
											{% if section.settings.enable_menu_item_first_level %}
												<a class="header__menu-link" href="{{link.url}}">
													{{ link.title | escape }}
												</a>
											{% else %}
												{{ link.title | escape }}
											{% endif %}
										</span>
										{% render 'icon-caret' %}
									</span>
									{% if mega_menu %}
										<div class="header__mega-menu mega-menu color-background-1">
											{% render 'mega-menu', link: link, blocks: section.blocks %}
										</div>
									{% elsif mega_menu_2 %}
										<div class="header__mega-menu mega-menu mega-menu-collections color-background-1">
										{% render 'mega-menu-collections', link: link, blocks: section.blocks %}
										</div>
									{% elsif mega_submenu %}
										{% render 'header-mega-submenu', link: link, section: section %}
									{% else %}
										{% render 'submenu', link: link, enable_menu_item_first_level: section.settings.enable_menu_item_first_level %}
									{% endif %}
								</li>
							{%- else -%}
								<li>
									<a href="{{ link.url }}" class="header__menu-item link-hover-line-outer list-menu__item link focus-inset"{% if link.current %} aria-current="page"{% endif %} aria-label="{{ link.title | escape }}">
										<span {%- if link.active %} class="header__active-menu-item"{% endif %} title="{{ link.title | escape }}">
											{{ link.title | escape }}
										</span>
									</a>
								</li>
							{%- endif -%}
					{%- endfor -%}
				</ul>
			{%- endif -%}
		</nav>

		<div class="header__column">
