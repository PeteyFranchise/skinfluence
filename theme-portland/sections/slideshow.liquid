{{ 'section-slideshow.css' | asset_url | stylesheet_tag }}
<script src="{{ 'slideshow.js' | asset_url }}" defer="defer"></script>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.25 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.25 | round: 0 }}px;
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    	padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1360px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<div class="slideshow section-{{ section.id }}-padding">
  <div
    {% if section.settings.full_width == false %}
      class="container"
    {% endif %}
  >
    <div class="slideshow__swiper swiper" data-autoplay="{{ section.settings.enable_autoplay }}">
      <div class="slideshow__wrapper swiper-wrapper">
        {% for block in section.blocks %}
          {% if section.settings.height != 'adapt' %}
            {% liquid
              assign aspect_ratio = section.settings.height | split: '/'
              assign temp = aspect_ratio[0] | append: '.0'
              assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
            %}
          {% else %}
            {% assign padding_bottom = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 | round: 2 %}
          {% endif %}
          {% style %}
            .section-{{ section.id }}-padding .slideshow__slide-{{ block.id }}::before {
							content: "";
							display: block;
							padding-bottom: {{ padding_bottom }}%;
						}
          {% endstyle %}
          <div
            class="slideshow__slide swiper-slide slideshow__slide-{{ block.id }} color-{{ block.settings.color_scheme }}"
            data-swiper-autoplay="{{ section.settings.slide_duration | times: 1000 }}"
            {{ block.shopify_attributes }}
          >
						{% if section.settings.full_width == true %}
							<div class="slideshow__slide-container container">
						{% endif %}
            <div class="media">
              <div class="slideshow__overlay" style="opacity: {{ block.settings.overlay_opacity }}"></div>
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 3000
                  | image_tag:
                    class: 'slideshow__image',
                    loading: 'lazy',
                    sizes: '100vw',
                    widths: '550, 720, 990, 1100, 1500, 2200, 3000'
                }}
              {% endif %}
            </div>
            <div class="slideshow__content-wrapper">
              {% if block.settings.subheading != blank %}
                <div class="slideshow__subheading subtitle">
                  {{ block.settings.subheading | escape }}
                </div>
              {% endif %}
              {% if block.settings.heading != blank %}
                <{{ block.settings.heading_tag }} class="slideshow__title title--section {% if block.settings.heading_size == 'medium' %}h2{% else %}h1{% endif %}">
                  {{ block.settings.heading }}
                </{{ block.settings.heading_tag }}>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="slideshow__description">
                  {{ block.settings.description }}
                </div>
              {% endif %}
              {% if block.settings.button_label != blank and block.settings.show_button %}
                <a
                  {% if block.settings.button_link.url != blank %}
                    href="{{ block.settings.button_link }}"
                  {% endif %}
                  class="slideshow__button button button--arrow button--{{ block.settings.button_style }} button--primary-size"
                  {% if block.settings.button_link.url == blank %}
                    aria-disabled="true"
                  {% endif %}
                >
                  <span>
                    <span>
                      {{ block.settings.button_label | escape }}
                      {% render 'icon-button-arrow' %}
                    </span>
                    <span>
                      {{ block.settings.button_label | escape }}
                      {% render 'icon-button-arrow' %}
                    </span>
                  </span>
                </a>
              {% endif %}
            </div>
						{% if section.settings.full_width == true %}
							</div>
						{% endif %}
          </div>
        {% endfor %}
      </div>
      {% if section.blocks.size > 1 %}
				{% if section.settings.full_width == true %}
					<div class="slideshow__container container">
				{% endif %}
					<div class="slideshow__controls no-js-hidden swiper-buttons swiper-buttons--{{ section.settings.button_style }}">
						<button
							class="slideshow__button--prev swiper-button-prev"
							aria-label="Prev"
						>
							{% render 'icon-caret-left' %}
						</button>
						<div class="slideshow__navigation swiper-pagination"></div>
						<button
							class="slideshow__button--next swiper-button-next"
							aria-label="Next"
						>
							{% render 'icon-caret-right' %}
						</button>
					</div>
				{% if section.settings.full_width == true %}
					</div>
				{% endif %}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.slideshow.name",
  "tag": "section",
  "class": "section-slideshow",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "t:sections.slideshow.settings.full_width.label"
    },
    {
      "type": "select",
      "id": "height",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.slideshow.settings.height.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.slideshow.settings.height.options__2.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.slideshow.settings.height.options__3.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.slideshow.settings.height.options__4.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.slideshow.settings.height.options__5.label"
        },
        {
          "value": "adapt",
          "label": "t:sections.slideshow.settings.height.options__6.label"
        }
      ],
      "default": "16/9",
      "label": "t:sections.slideshow.settings.height.label"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "default": false,
      "label": "t:sections.slideshow.settings.enable_autoplay.label"
    },
		{
			"type": "range",
			"id": "slide_duration",
			"default": 5,
			"min": 1,
			"max": 10,
			"unit": "s",
			"label": "t:sections.slideshow.settings.slide_duration.label"
		},
    {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:all.button.button_style.options__3.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.slideshow.settings.button_style.label"
    },
    {
      "type": "header",
      "content": "t:all.section-padding.header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 160,
      "unit": "px",
      "label": "t:all.section-padding.padding_top.label"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 160,
      "unit": "px",
      "label": "t:all.section-padding.padding_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.slideshow.blocks.slide.name",
      "settings": [
        {
          "type": "select",
          "id": "color_scheme",
          "options": [
            {
              "value": "background-1",
              "label": "t:all.color_scheme.options__5.label"
            },
            {
              "value": "background-3",
              "label": "t:all.color_scheme.options__6.label"
            }
          ],
          "default": "background-3",
          "label": "t:all.color_scheme.label"
        },
        {
          "type": "text",
          "id": "subheading",
          "default": "t:sections.slideshow.blocks.slide.settings.subheading.default",
          "label": "t:all.subheading.label"
        },
        {
          "type": "textarea",
          "id": "heading",
          "default": "t:sections.slideshow.blocks.slide.settings.heading.default",
          "label": "t:all.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "medium",
              "label": "t:all.heading_size.options__1.label"
            },
            {
              "value": "large",
              "label": "t:all.heading_size.options__2.label"
            }
          ],
          "default": "medium",
          "label": "t:all.heading_size.label"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "options": [
            {
              "value": "h1",
              "label": "t:all.heading_tag.options__1.label"
            },
            {
              "value": "h2",
              "label": "t:all.heading_tag.options__2.label"
            },
            {
              "value": "h3",
              "label": "t:all.heading_tag.options__3.label"
            },
            {
              "value": "h4",
              "label": "t:all.heading_tag.options__4.label"
            },
            {
              "value": "h5",
              "label": "t:all.heading_tag.options__5.label"
            },
            {
              "value": "h6",
              "label": "t:all.heading_tag.options__6.label"
            },
            {
              "value": "div",
              "label": "t:all.heading_tag.options__7.label"
            },
            {
              "value": "p",
              "label": "t:all.heading_tag.options__8.label"
            }
          ],
          "default": "h2",
          "label": "t:all.heading_tag.label",
          "info": "t:all.heading_tag.info"
        },
        {
          "type": "textarea",
          "id": "description",
          "default": "t:sections.slideshow.blocks.slide.settings.description.default",
          "label": "t:all.text.label"
        },
        {
          "type": "header",
          "content": "t:all.button.header_button.content"
        },
        {
          "type": "checkbox",
          "id": "show_button",
          "default": true,
          "label": "t:all.button.button_show.label"
        },
        {
          "type": "select",
          "id": "button_style",
          "options": [
            {
              "value": "primary",
              "label": "t:all.button.button_style.options__1.label"
            },
            {
              "value": "secondary",
              "label": "t:all.button.button_style.options__2.label"
            },
            {
              "value": "tertiary",
              "label": "t:all.button.button_style.options__3.label"
            }
          ],
          "default": "primary",
          "label": "t:all.button.button_style.label"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "t:sections.slideshow.blocks.slide.settings.button_label.default",
          "label": "t:all.button.button_label.label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:all.button.button_link.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.slideshow.settings.image.label"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 1,
          "step": 0.1,
          "label": "t:sections.slideshow.settings.overlay_opacity.label",
          "default": 0.5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.slideshow.presets.name",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
