{{ 'section-collapsible-content.css' | asset_url | stylesheet_tag }}

<script src="{{ 'collapsible-content.js' | asset_url }}" defer="defer"></script>

{%- style -%}
	.section-{{ section.id }}-padding {
		padding-top: {{ section.settings.padding_top | times: 0.25 | round: 0 }}px;
		padding-bottom: {{ section.settings.padding_bottom | times: 0.25 | round: 0 }}px;
	}

	@media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    	padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
  }

	@media screen and (min-width: 1360px) {
		.section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}
{%- endstyle -%}

<div class="collapsible-content section-{{ section.id }}-padding">
	<div class="container">
		<div class="collapsible-content__top">
			{%- if section.settings.heading != blank -%}
				<{{ section.settings.heading_tag }} class="collapsible-content__heading {{ section.settings.heading_size }}">
					{{ section.settings.heading }}
				</{{ section.settings.heading_tag }}>
			{%- endif -%}

			{%- if section.settings.text != blank -%}
				<div class="collapsible-content__text">
					{{ section.settings.text | escape }}
				</div>
			{%- endif -%}
		</div>

		<div class="collapsible-content__items">
			{%- for block in section.blocks -%}
				<div class="collapsible-content__item {% if forloop.index == 1 %} active{% endif %}" {{ block.shopify_attributes }}>
					<div class="collapsible-content__toggle">
						<div class="collapsible-content__toggle-group">
							<div class="collapsible-content__digit">{{ forloop.index }}</div>
							{%- if block.settings.question != blank -%}
								<{{ block.settings.question_heading_tag }} class="collapsible-content__question h3">{{ block.settings.question | escape }}</{{ block.settings.question_heading_tag }}>
							{%- endif -%}
						</div>
						<div class="collapsible-content__icon">
							{% render 'icon-button-arrow' %}
							{% render 'icon-button-arrow' %}
						</div>
					</div>

					{%- if block.settings.answer != blank -%}
						<div class="collapsible-content__answer" {% if forloop.index == 1 %} style="display: block;" {% endif %}>
							<div class="collapsible-content__answer-inner">{{ block.settings.answer }}</div>
						</div>
					{%- endif -%}
				</div>
			{%- endfor -%}
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.collapsible-content.name",
	"tag": "section",
	"class": "collapsible-content-section spaced-section",
	"enabled_on": {
		"templates": [
			"*"
		]
	},
	"blocks": [
		{
			"type": "accordion",
			"name": "t:sections.collapsible-content.blocks.accordion.name",
			"limit": 20,
			"settings": [
				{
					"type": "text",
					"id": "question",
					"default": "t:sections.collapsible-content.blocks.settings.question.default",
					"label": "t:sections.collapsible-content.settings.heading.label"
				},
				{
					"type": "select",
					"id": "question_heading_tag",
					"options": [
						{
							"value": "h1",
							"label": "t:all.heading_tag.options__1.label"
						},
						{
							"value": "h2",
							"label": "t:all.heading_tag.options__2.label"
						},
						{
							"value": "h3",
							"label": "t:all.heading_tag.options__3.label"
						},
						{
							"value": "h4",
							"label": "t:all.heading_tag.options__4.label"
						},
						{
							"value": "h5",
							"label": "t:all.heading_tag.options__5.label"
						},
						{
							"value": "h6",
							"label": "t:all.heading_tag.options__6.label"
						},
						{
							"value": "div",
							"label": "t:all.heading_tag.options__7.label"
						},
						{
							"value": "p",
							"label": "t:all.heading_tag.options__8.label"
						}
					],
					"default": "h3",
					"label": "t:all.heading_tag.label",
					"info": "t:all.heading_tag.info"
				},
				{
					"type": "richtext",
					"id": "answer",
					"default": "t:sections.collapsible-content.blocks.settings.answer.default",
					"label": "t:sections.collapsible-content.settings.text.label"
				}
			]
		}
	],
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"default": "t:sections.collapsible-content.settings.heading.default",
			"label": "t:sections.collapsible-content.settings.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h3",
					"label": "t:sections.collapsible-content.settings.heading_size.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:sections.collapsible-content.settings.heading_size.options__2.label"
				},
				{
					"value": "h1",
					"label": "t:sections.collapsible-content.settings.heading_size.options__3.label"
				}
			],
			"default": "h2",
			"label": "t:sections.collapsible-content.settings.heading_size.label"
		},
		{
			"type": "select",
			"id": "heading_tag",
			"options": [
				{
					"value": "h1",
					"label": "t:all.heading_tag.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:all.heading_tag.options__2.label"
				},
				{
					"value": "h3",
					"label": "t:all.heading_tag.options__3.label"
				},
				{
					"value": "h4",
					"label": "t:all.heading_tag.options__4.label"
				},
				{
					"value": "h5",
					"label": "t:all.heading_tag.options__5.label"
				},
				{
					"value": "h6",
					"label": "t:all.heading_tag.options__6.label"
				},
				{
					"value": "div",
					"label": "t:all.heading_tag.options__7.label"
				},
				{
					"value": "p",
					"label": "t:all.heading_tag.options__8.label"
				}
			],
			"default": "h2",
			"label": "t:all.heading_tag.label",
			"info": "t:all.heading_tag.info"
		},
		{
			"type": "textarea",
			"id": "text",
			"default": "t:sections.collapsible-content.settings.text.default",
			"label": "t:sections.collapsible-content.settings.text.label"
		},
		{
			"type": "header",
			"content": "t:all.section-padding.header.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 160,
			"unit": "px",
			"label": "t:all.section-padding.padding_top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 160,
			"unit": "px",
			"label": "t:all.section-padding.padding_bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.collapsible-content.name",
			"blocks": [
				{
					"type": "accordion"
				},
				{
					"type": "accordion"
				},
				{
					"type": "accordion"
				}
			]
		}
	]
}
{% endschema %}