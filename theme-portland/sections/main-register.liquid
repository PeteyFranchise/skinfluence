{{ 'customer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'input.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'parallax.js' | asset_url }}" defer="defer"></script>

<div class="article-template {% if section.settings.color_scheme == 'background-3' or section.settings.color_scheme == 'background-4' %}section--has-overlay{% endif %}">
  <div class="customer login register color-{{ section.settings.color_scheme }}">
    <div class="login__bg parallax">
      {%- for block in section.blocks -%}
        <div
          class="login__bg-image parallax-layer"
          {% if forloop.index == 1 or forloop.index == 3 or forloop.index == 5 %}
            data-parallax-deep="80"
          {% else %}
            data-parallax-deep="160"
          {% endif %}
        >
          {%- if block.settings.image != blank -%}
            {%- capture sizes -%}
							(min-width: 1100px) calc({{ block.settings.image.width | times: 1920 | divided_by: 100 | round }}vw), (min-width: 990px) calc({{ block.settings.image.width | times: 1920 | divided_by: 100 | round }})vw, (min-width: 750px) calc({{ block.settings.image.width | times: 1920 | divided_by: 100 | round }})vw
						{%- endcapture -%}

            {%- capture speed -%}
							{% if forloop.index == 1 or forloop.index == 3 or forloop.index == 5 or forloop.index == 7 %} -80 {% else %} -115 {% endif %}
						{%- endcapture -%}

            {{
              block.settings.image.preview_image
              | image_url: width: 1946
              | image_tag:
                data-parallax-property: 'translateY',
                data-parallax-property-value: speed,
                data-parallax-steps: '0, 100',
                class: 'image-parallax__image js-parallax',
                loading: lazy,
                sizes: sizes,
                widths: '246, 493, 600, 713, 823, 990, 1100, 1206, 1346, 1426, 1646, 1946'
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'login__bg-image-placeholder' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div
      class="login__overlay"
      style="background-color: rgba(var(--color-overlay), {{ section.settings.opacity_overlay }})"
    ></div>

    <div class="login__reset">
      <div class="page-header" id="recover">
        <div class="page-header__inner">
          <h1 class="main-page-title page-title title--page" tabindex="-1">
            {{ 'customer.recover_password.title' | t }}
          </h1>
        </div>
      </div>
      <div>
        <p>
          {{ 'customer.recover_password.subtext' | t }}
        </p>

        {%- form 'recover_customer_password' -%}
          {% assign recover_success = form.posted_successfully? %}
          <div class="field {% if section.settings.color_scheme == 'background-3' or section.settings.color_scheme == 'background-4' %}field--dark{% endif %}">
            <input
              dir="ltr"
              type="email"
              value=""
              name="email"
              id="RecoverEmail"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="RecoverEmail-email-error"
                autofocus
              {% endif %}
              placeholder="{{ 'customer.login_page.email' | t }}"
            >
            <label for="RecoverEmail">{{ 'customer.login_page.email' | t }}</label>
          </div>

          <div class="customer__buttons login__buttons">
            <button class="button button--primary button--arrow login__sign-in">
              <span>
                <span>{{ 'customer.login_page.submit' | t }}</span>
                <span>{{ 'customer.login_page.submit' | t }}</span>
              </span>
            </button>

            <a class="button button--tertiary login__create-acc" href="#login">
              <span>
                <span>{{ 'customer.login_page.cancel' | t }}</span>
                <span>{{ 'customer.login_page.cancel' | t }}</span>
              </span>
            </a>
          </div>
        {%- endform -%}
      </div>
    </div>

    <div class="login__form">
      <div class="page-header">
        <div class="page-header__inner">
          {% if settings.show_breadcrumbs %}
            <div class="container">
              <nav class="breadcrumb breadcrumb--center" role="navigation" aria-label="breadcrumbs">
                <a href="{{ routes.root_url }}" title="{{ 'general.breadcrumbs.home' | t }}" class="link-hover-line">
                  {{ 'general.breadcrumbs.home' | t }}
                </a>
                <div class="breadcrumb__delimiter"></div>
                <span>{{ 'customer.register.breadcrumb' | t }}</span>
              </nav>
            </div>
          {% endif %}

          <h1 class="title--page">{{ 'customer.register.title' | t }}</h1>

          {%- if section.settings.subtitle != blank -%}
            <div class="login__subtitle">
              {{ section.settings.subtitle }}
            </div>
          {%- endif -%}
        </div>
      </div>
      {%- form 'create_customer', novalidate: 'novalidate' -%}
        <div class="field__wrapper">
          <div class="field {% if section.settings.color_scheme == 'background-3' or section.settings.color_scheme == 'background-4' %}field--dark{% endif %}">
            <div class="field-container">
              <input
                dir="ltr"
                type="text"
                name="customer[first_name]"
                id="RegisterForm-FirstName"
                {% if form.first_name %}
                  value="{{ form.first_name }}"
                {% endif %}
                autocomplete="given-name"
                placeholder="{{ 'customer.register.first_name' | t }}"
                required
              >
              <label for="RegisterForm-FirstName">{{ 'customer.register.first_name' | t }}</label>
            </div>  
            {%- if form.errors contains 'first_name' -%}
              <span id="RegisterForm-first_name-error" class="form__message">
                {{ form.errors.translated_fields.first_name | capitalize }}
                {{ form.errors.messages.first_name }}.
              </span>
            {%- endif -%}
          </div>
          <div class="field {% if section.settings.color_scheme == 'background-3' or section.settings.color_scheme == 'background-4' %}field--dark{% endif %}">
            <div class="field-container">
              <input
                dir="ltr"
                type="text"
                name="customer[last_name]"
                id="RegisterForm-LastName"
                {% if form.last_name %}
                  value="{{ form.last_name }}"
                {% endif %}
                autocomplete="family-name"
                aria-required="true"
                placeholder="{{ 'customer.register.last_name' | t }}"
                required
              >
              <label for="RegisterForm-LastName">{{ 'customer.register.last_name' | t }}</label>
            </div>
            {%- if form.errors contains 'last_name' -%}
              <span id="RegisterForm-last_name-error" class="form__message">
                {{ form.errors.translated_fields.last_name | capitalize }}
                {{ form.errors.messages.last_name }}.
              </span>
            {%- endif -%}
          </div>
        </div>

        <div class="field {% if section.settings.color_scheme == 'background-3' or section.settings.color_scheme == 'background-4' %}field--dark{% endif %}">
          <input
            dir="ltr"
            type="email"
            name="customer[email]"
            id="RegisterForm-email"
            {% if form.email %}
              value="{{ form.email }}"
            {% endif %}
            spellcheck="false"
            autocapitalize="off"
            autocomplete="email"
            aria-required="true"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="RegisterForm-email-error"
            {% endif %}
            placeholder="{{ 'customer.register.email' | t }}"
            required
          >
          <label for="RegisterForm-email">{{ 'customer.register.email' | t }}</label>
        </div>
        {%- if form.errors contains 'email' -%}
          <span id="RegisterForm-email-error" class="form__message">
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}.
          </span>
        {%- endif -%}
        <div class="field {% if section.settings.color_scheme == 'background-3' or section.settings.color_scheme == 'background-4' %}field--dark{% endif %}">
          <input
            dir="ltr"
            type="password"
            name="customer[password]"
            id="RegisterForm-password"
            aria-required="true"
            {% if form.errors contains 'password' %}
              aria-invalid="true"
              aria-describedby="RegisterForm-password-error"
            {% endif %}
            placeholder="{{ 'customer.register.password' | t }}"
            required
          >
          <label for="RegisterForm-password">{{ 'customer.register.password' | t }}</label>
        </div>
        {%- if form.errors contains 'password' -%}
          <span id="RegisterForm-password-error" class="form__message">
            {{ form.errors.translated_fields.password | capitalize }}
            {{ form.errors.messages.password }}.
          </span>
        {%- endif -%}

        {%- if form.errors contains 'form' -%}
          <span id="RegisterForm-email-error" class="form__message">
            {{ 'customer.login_page.customer_exist' | t }}
          </span>
        {%- endif -%}

        <div class="login__forgot-password">
          <a href="#recover">{{ 'customer.login_page.forgot_password' | t }}</a>
        </div>

        <div class="customer__buttons center">
          <button class="button button--tertiary button--arrow">
            <span>
              <span>{{ 'customer.register.submit' | t }}</span>
              <span>{{ 'customer.register.submit' | t }}</span>
            </span>
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-register.name",
  "tag": "section",
  "class": "spaced-section login-section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "background-1",
          "label": "t:sections.main-login.settings.color_scheme.options__1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.main-login.settings.color_scheme.options__2.label"
        },
        {
          "value": "background-5",
          "label": "t:sections.main-login.settings.color_scheme.options__5.label"
        },
        {
          "value": "background-3",
          "label": "t:sections.main-login.settings.color_scheme.options__3.label"
        },
        {
          "value": "background-4",
          "label": "t:sections.main-login.settings.color_scheme.options__4.label"
        }
      ],
      "default": "background-1",
      "label": "t:sections.main-login.settings.color_scheme.label"
    },
    {
      "type": "range",
      "id": "opacity_overlay",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "t:sections.main-login.settings.opacity_overlay.label",
      "default": 0.5
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "default": "Register to access your account and manage your settings.",
      "label": "t:sections.main-register.settings.text.label"
    }
  ],
  "blocks": [
    {
      "name": "t:sections.main-register.blocks.name",
      "type": "column",
      "limit": 7,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.main-register.blocks.settings.image.label"
        }
      ]
    }
  ]
}
{% endschema %}
