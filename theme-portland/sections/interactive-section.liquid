{% schema %}
{
	"name": "t:sections.interactive-section.name",
	"tag": "section",
	"class": "interactive-section image-section section--overlay",
	"limit": 1,
	"enabled_on": {
    "templates": ["*"]
  },
	"settings": [
		{
			"type": "select",
			"id": "color_scheme",
			"options": [
				{
					"value": "background-1",
					"label": "t:sections.interactive-section.settings.color_scheme.options__1.label"
				},
				{
					"value": "background-2",
					"label": "t:sections.interactive-section.settings.color_scheme.options__2.label"
				},
				{
					"value": "background-5",
					"label": "t:sections.interactive-section.settings.color_scheme.options__5.label"
				},
				{
					"value": "background-3",
					"label": "t:sections.interactive-section.settings.color_scheme.options__3.label"
				},
				{
					"value": "background-4",
					"label": "t:sections.interactive-section.settings.color_scheme.options__4.label"
				}
			],
			"default": "background-1",
			"label": "t:sections.interactive-section.settings.color_scheme.label"
		},
		{	
			"type": "checkbox",
			"id": "overlay",
			"default": true,
			"label": "t:sections.interactive-section.settings.overlay.label"
		},
		{
      "type": "range",
      "id": "opacity_overlay",
      "min": 0,
			"max": 1,
			"step": 0.1,
      "label": "t:sections.interactive-section.settings.opacity_overlay.label",
      "default": 0.7
    },
		{
			"type": "select",
			"id": "collage_type",
			"options": [
				{
					"value": "on-cursor",
					"label": "t:sections.interactive-section.settings.collage_type.options__1.label"
				},
				{
					"value": "vertical-marquee",
					"label": "t:sections.interactive-section.settings.collage_type.options__2.label"
				}
			],
			"default": "on-cursor",
			"label": "t:sections.interactive-section.settings.collage_type.label",
			"info": "t:sections.interactive-section.settings.collage_type.info"
		},
		{
			"type": "header",
			"content": "t:sections.interactive-section.settings.heading_label.content"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h1",
					"label": "t:sections.interactive-section.settings.heading_size.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:sections.interactive-section.settings.heading_size.options__2.label"
				}
			],
			"default": "h1",
			"label": "t:sections.interactive-section.settings.heading_size.label"
		},
		{
			"type": "text",
			"id": "subheading",
			"default": "t:sections.interactive-section.settings.subheading.default",
			"label": "t:sections.interactive-section.settings.subheading.label"
		},
		{
			"type": "richtext",
			"id": "heading",
			"default": "t:sections.interactive-section.settings.heading.default",
			"label": "t:sections.interactive-section.settings.heading.label"
		},
		{
			"type": "header",
			"content": "t:sections.interactive-section.settings.header__1.content"
		},
		{
			"type": "checkbox",
			"id": "show_view_all",
			"default": true,
			"label": "t:sections.interactive-section.settings.show_view_all.label"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "t:sections.interactive-section.settings.button_label.default",
			"label": "t:sections.interactive-section.settings.button_label.label"
		},
		{
			"type": "color",
			"id": "button_bg_color",
			"default": "#FFFFFF",
			"label": "t:sections.interactive-section.settings.button_bg_color.label"
		},
		{
			"type": "color",
			"id": "button_text_color",
			"default": "#000000",
			"label": "t:sections.interactive-section.settings.button_bg_color.label"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "t:sections.interactive-section.settings.button_link.label"
		},
		{
			"type": "header",
			"content": "t:sections.interactive-section.settings.header__2.content"
		},
		{
			"type": "checkbox",
			"id": "second_show_view_all",
			"default": false,
			"label": "t:sections.interactive-section.settings.show_view_all.label"
		},
		{
