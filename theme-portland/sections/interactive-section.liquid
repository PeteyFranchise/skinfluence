{{ 'section-image.css' | asset_url | stylesheet_tag }}
{{ 'section-interactive-section.css' | asset_url | stylesheet_tag }}

<script src="{{ 'interactive-section.js' | asset_url }}" defer="defer"></script>

{% style %}
	.image-parallax__button {
		background-color: {{ section.settings.button_bg_color }};
		color: {{ section.settings.button_text_color }};
	}

	.second_image-parallax__button {
		background-color: {{ section.settings.second_button_bg_color }};
		color: {{ section.settings.second_button_text_color }};
	}

	[data-scheme='dark'] .image-parallax__button {
		background-color: #fff;
		color: #000;
	}
	
	@media (prefers-color-scheme: dark) {
		[data-scheme="auto"] .image-parallax__button {
			background-color: #fff;
			color: #000;
		}
	}
{% endstyle %}

<div class="image-parallax color-{{- section.settings.color_scheme -}}">
	<div class="image-parallax__bg-outer">
		<div class="image-parallax__bg-inner">
			<div class="image-parallax__bg image-parallax__bg--{{ section.settings.collage_type }} {%- if section.settings.collage_type == 'on-cursor' -%}parallax{% endif %}">
				{%- if section.settings.collage_type == 'on-cursor' -%}
					{%- for block in section.blocks limit: 8 -%}
						<div class="parallax-layer image-parallax__bg-image" {% if forloop.index == 1 or forloop.index == 3 or forloop.index == 5 or forloop.index == 7 %} data-parallax-deep="80" {% else %} data-parallax-deep="160" {% endif %} {{ block.shopify_attributes }}>
							<div class="image-parallax__scroll-parallax js-parallax"
									 data-parallax-property="translateY"
									 data-parallax-property-value="{% if forloop.index == 1 or forloop.index == 3 or forloop.index == 5 or forloop.index == 7 %} -80 {% else %} -115 {% endif %}"
									 data-parallax-steps="0, 100"
							>
								{%- if block.settings.image != blank -%}

									{%- capture style -%}
										object-position: {{ block.settings.image.presentation.focal_point }};
									{%- endcapture -%}

									{{
										block.settings.image.preview_image | image_url: width: 1946 | image_tag:
										class: 'image-parallax__image',
										loading: 'lazy',
										widths: '246, 493, 600, 713, 823, 990, 1100, 1206, 1346, 1426, 1646, 1946',
										style: style
									}}

								{%- endif -%}
							</div>
						</div>
					{%- endfor -%}
				{% else %}
				{%- capture sizes -%}
					(min-width: 749px) 20vw,
					33vw
				{%- endcapture -%}
				{% assign widths = '300, 600' %}
					{%- for block in section.blocks -%}
						{% capture style %}
							object-position: {{ block.settings.image.presentation.focal_point }};
							aspect-ratio: {{ block.settings.image.aspect_ratio }};
						{% endcapture %}
						{%- assign height = 300 | divided_by: block.settings.image.aspect_ratio | round: 2 -%}

