{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.25 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.25 | round: 0 }}px;
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1360px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .trust-marquee-{{ section.id }} {
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
  }

  .trust-marquee-{{ section.id }} .trust-marquee__inner {
    display: flex;
    width: max-content;
    align-items: center;
    gap: {{ section.settings.item_gap }}px;
    animation: trust-marquee-{{ section.id }} {{ section.settings.speed }}s linear infinite;
    padding: 0.95rem 0;
  }

  .trust-marquee-{{ section.id }} .trust-marquee__track {
    display: flex;
    align-items: center;
    gap: {{ section.settings.item_gap }}px;
    flex-shrink: 0;
    padding-right: {{ section.settings.item_gap }}px;
  }

  .trust-marquee-{{ section.id }} .trust-marquee__item {
    display: inline-flex;
    align-items: center;
    gap: {{ section.settings.separator_gap }}px;
    white-space: nowrap;
    font-size: {{ section.settings.text_size }}px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    line-height: 1;
    opacity: 0.92;
  }

  .trust-marquee-{{ section.id }} .trust-marquee__icon {
    display: inline-flex;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    flex: 0 0 {{ section.settings.icon_size }}px;
    align-items: center;
    justify-content: center;
    opacity: {{ section.settings.icon_opacity }};
  }

  .trust-marquee-{{ section.id }} .trust-marquee__icon svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .trust-marquee-{{ section.id }} .trust-marquee__separator {
    opacity: 0.42;
  }

  @keyframes trust-marquee-{{ section.id }} {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-marquee-{{ section.id }} .trust-marquee__inner {
      animation: none;
      width: 100%;
      justify-content: center;
    }

    .trust-marquee-{{ section.id }} .trust-marquee__track:last-child {
      display: none;
    }
  }
{% endstyle %}

{% liquid
  assign item_count = section.blocks.size
%}

{% if item_count > 0 %}
  <section class="section-{{ section.id }}-padding">
    <div class="trust-marquee trust-marquee-{{ section.id }}">
      <div class="trust-marquee__inner" aria-label="{{ section.settings.accessibility_label | escape }}">
        {% for duplicate in (1..2) %}
          <div class="trust-marquee__track">
            {% for block in section.blocks %}
              <span class="trust-marquee__item" {{ block.shopify_attributes }}>
                {% if section.settings.show_icons %}
                  <span class="trust-marquee__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 9" fill="none">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M11.35.643a.5.5 0 01.006.707l-6.77 6.886a.5.5 0 01-.719-.006L.638 4.845a.5.5 0 11.724-.69l2.872 3.011 6.41-6.517a.5.5 0 01.707-.006h-.001z" fill="currentColor"/>
                    </svg>
                  </span>
                {% endif %}
                <span>{{ block.settings.text | escape }}</span>
                {% unless forloop.last %}
                  <span class="trust-marquee__separator" aria-hidden="true">{{ section.settings.separator }}</span>
                {% endunless %}
              </span>
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Trust marquee",
  "tag": "section",
  "class": "spaced-section",
  "enabled_on": {
    "templates": ["index", "page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "default": "PROTOCL trust highlights"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#F1ECE6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#20332C"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "•"
    },
    {
      "type": "checkbox",
      "id": "show_icons",
      "label": "Show icons",
      "default": true
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Icon size",
      "default": 11
    },
    {
      "type": "range",
      "id": "icon_opacity",
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "label": "Icon opacity",
      "default": 0.7
    },
    {
      "type": "range",
      "id": "speed",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "s",
      "label": "Animation speed",
      "default": 30
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 13
    },
    {
      "type": "range",
      "id": "item_gap",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Space between items",
      "default": 44
    },
    {
      "type": "range",
      "id": "separator_gap",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Space around separator",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Provider-reviewed care"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust marquee",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "text": "Provider-reviewed care"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "High-Performance anti-aging treatment"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "Monthly care if approved"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "Delivered to your door"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "Ongoing maintenance support"
          }
        }
      ]
    }
  ]
}
{% endschema %}
