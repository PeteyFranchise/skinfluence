{{ 'component-card-extended.css' | asset_url | stylesheet_tag }}
{{ 'section-categories-list.css' | asset_url | stylesheet_tag }}

<script src="{{ 'categories-list.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.25 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.25 | round: 0 }}px;
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    	padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1360px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="categories-list color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="container">
    <div class="categories-list__wrapper">
      <div class="categories-list__text">
        {% if section.settings.subheading != blank or section.settings.heading != blank %}
          <div class="categories-list__top-text">
            {% if section.settings.subheading != blank %}
              <div class="categories-list__subheading subtitle">
                {{ section.settings.subheading }}
              </div>
            {% endif %}
            {%- if section.settings.heading != blank -%}
              <{{ section.settings.heading_tag }} class="categories-list__heading h2">
                {{ section.settings.heading }}
              </{{ section.settings.heading_tag }}>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="categories-list__title-list">
          {%- for block in section.blocks -%}
            <h3
              class="categories-list__title h4"
              data-index="{{ forloop.index }}"
            >
              <a
                {% if block.settings.collection != blank %}
                  href="{{ block.settings.collection.url }}"
                {% endif %}
                class="categories-list__link"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.collection != blank %}
                  {{ block.settings.collection.title }}
                {% else %}
                  {{- 'general.card.collection_name' | t -}}
                {% endif %}
                <div class="categories-list__more">
                  <div class="categories-list__more-text">
                    {% render 'icon-button-arrow' %}
                    <span>{{ 'sections.categories-list.more' | t }}</span>
                  </div>
                  <div class="categories-list__more-icon">
                    {% render 'icon-button-arrow' %}
                  </div>
                </div>
              </a>
            </h3>
          {%- endfor -%}
        </div>
      </div>
      <div class="categories-list__products">
        {%- for block in section.blocks -%}
          {% if section.settings.product_image == 'second' and block.settings.product.media[1] != blank %}
            {% assign show_img = true %}
          {% else %}
            {% assign show_img = false %}
          {% endif %}

          <div
            class="
							categories-list__product collection-hero__product-card
              {% if show_img == true %} categories-list__product--{{- section.settings.product_image -}} {% endif %}
							{% if block.settings.product == blank %} categories-list__product-placeholder {% endif %}
							{% if forloop.first %} active {% endif %}
            "
            data-index="{{ forloop.index }}"
          >
            {% if block.settings.product != blank %}
              {% render 'product-card-extended',
                product_card_product: block.settings.product,
                media_size: section.settings.image_ratio,
                media_fit: section.settings.image_fit,
                show_secondary_image: show_img,
                show_vendor: section.settings.show_vendor,
                show_sku: section.settings.show_sku
              %}
            {% else %}
              {% render 'product-card-placeholder',
                media_size: section.settings.image_ratio,
                show_vendor: section.settings.show_vendor,
                forloop: forloop
              %}
            {% endif %}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.categories-list.name",
  "tag": "section",
  "class": "categories-list-section spaced-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "background-1",
          "label": "t:sections.categories-list.settings.color_scheme.options__1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.categories-list.settings.color_scheme.options__2.label"
        }
      ],
      "default": "background-2",
      "label": "t:sections.categories-list.settings.color_scheme.label"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.categories-list.settings.subheading.label",
      "default": "t:sections.categories-list.settings.subheading.default"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "t:sections.categories-list.settings.heading.label",
      "default": "t:sections.categories-list.settings.heading.default"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:all.heading_tag.options__7.label"
        },
        {
          "value": "p",
          "label": "t:all.heading_tag.options__8.label"
        }
      ],
      "default": "h2",
      "label": "t:all.heading_tag.label",
      "info": "t:all.heading_tag.info"
    },
    {
      "type": "header",
      "content": "t:sections.featured-products.settings.header.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.featured-products.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.featured-products.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.featured-products.settings.image_ratio.options__3.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.featured-products.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "t:sections.featured-products.settings.image_fit.label",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.featured-products.settings.image_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.featured-products.settings.image_fit.options__2.label"
        }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "product_image",
      "label": "t:sections.categories-list.settings.product_image.label",
      "options": [
        {
          "value": "first",
          "label": "t:sections.categories-list.settings.product_image.options__1.label"
        },
        {
          "value": "second",
          "label": "t:sections.categories-list.settings.product_image.options__2.label"
        }
      ],
      "default": "second"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "t:sections.featured-products.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "default": false,
      "label": "t:sections.featured-products.settings.show_sku.label"
    },
    {
      "type": "header",
      "content": "t:all.section-padding.header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 160,
      "unit": "px",
      "label": "t:all.section-padding.padding_top.label"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 160,
      "unit": "px",
      "label": "t:all.section-padding.padding_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "categories",
      "name": "t:sections.categories-list.blocks.categories.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.categories-list.blocks.categories.settings.collection.label"
        },
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.categories-list.blocks.categories.settings.product.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.categories-list.presets.name",
      "blocks": [
        {
          "type": "categories"
        },
        {
          "type": "categories"
        },
        {
          "type": "categories"
        }
      ]
    }
  ]
}
{% endschema %}
